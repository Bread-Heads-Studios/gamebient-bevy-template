# Rust build output
/target

# Web build output — regenerated by build_web.sh (Vercel buildCommand) and by
# the Docker build stage. Never commit; it bloats the repo by ~250 MB.
/dist

# Pi staging build outputs: the compiled binary and the asset copies are both
# regenerated from source. Only the hand-written run.sh launcher is kept tracked.
/dist-pi/gamebient-game
/dist-pi/assets/

# build.sh intermediates and the root distribution tarball it emits.
/gamebient-game.tar.gz

# The Pi cartridge binary is no longer stored in git: it's published as a GitHub
# release asset and fetched into dist/ at build time (see fetch-cartridge.sh).
/assets/gamebient-game.tar.gz

# Multi-target package output (build.sh / package.sh)
/build/

# OS / editor noise
.DS_Store
*.swp
.idea/
*.code-workspace
